<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/brand_pale">

    <!-- 닫기 -->
    <ImageButton
        android:id="@+id/pClose"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_margin="8dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="닫기"
        android:tint="#5D4037" />

    <!-- 큰 음표 아트 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_play_circle"
            android:alpha="0.12" />

        <TextView
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:text="♪"
            android:textSize="120sp"
            android:textColor="@color/brand"
            android:gravity="center" />
    </FrameLayout>

    <TextView
        android:id="@+id/pTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:text="@string/no_song"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/on_surface"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- 진행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp">

        <TextView
            android:id="@+id/pCurrent"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textSize="15sp"
            android:textColor="@color/muted" />

        <SeekBar
            android:id="@+id/pSeek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="1000"
            android:progressTint="@color/brand"
            android:thumbTint="@color/brand" />

        <TextView
            android:id="@+id/pTotal"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textSize="15sp"
            android:textColor="@color/muted"
            android:gravity="end" />
    </LinearLayout>

    <!-- 컨트롤 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="32dp">

        <ImageButton
            android:id="@+id/pPrev"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_prev"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:contentDescription="이전 곡" />

        <ImageButton
            android:id="@+id/pPlay"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginHorizontal="28dp"
            android:src="@drawable/ic_play_white"
            android:background="@drawable/bg_play_circle"
            android:scaleType="fitCenter"
            android:padding="24dp"
            android:contentDescription="재생/일시정지" />

        <ImageButton
            android:id="@+id/pNext"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_next"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="14dp"
            android:contentDescription="다음 곡" />
    </LinearLayout>

    <Button
        android:id="@+id/pRepeat"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"
        android:text="↻ 전체반복"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_pill"
        android:textColor="#5D4037" />
</LinearLayout>
