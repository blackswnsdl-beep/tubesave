<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="14dp"
    android:background="?attr/selectableItemBackground">

    <CheckBox
        android:id="@+id/songCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:scaleX="1.3"
        android:scaleY="1.3"
        android:visibility="gone" />

    <TextView
        android:id="@+id/songTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="20sp"
        android:textColor="@color/on_surface"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/songDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textSize="16sp"
        android:textColor="@color/muted" />

    <!-- 즐겨찾기 별 (전체 곡 탭에서만) -->
    <ImageButton
        android:id="@+id/btnFav"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_star_border"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:padding="10dp"
        android:contentDescription="즐겨찾기"
        android:visibility="gone" />

    <!-- 순서 이동 (재생목록 탭에서만) -->
    <ImageButton
        android:id="@+id/btnMoveUp"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_up"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:padding="10dp"
        android:contentDescription="위로 이동"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/btnMoveDown"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_down"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:padding="10dp"
        android:contentDescription="아래로 이동"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/dragHandle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="2dp"
        android:src="@android:drawable/ic_menu_sort_by_size"
        android:padding="10dp"
        android:contentDescription="끌어서 순서 이동"
        android:visibility="gone" />

    <!-- 스와이프하면 나타나는 삭제 버튼 (탭하면 휴지통으로) -->
    <Button
        android:id="@+id/btnSwipeDelete"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="6dp"
        android:text="삭제"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_btn_danger"
        android:textColor="#FFFFFF"
        android:visibility="gone" />
</LinearLayout>
