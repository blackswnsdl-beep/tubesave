<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 설정 화면용 스타일 (어르신용: 큰 글씨, 넉넉한 여백, 명확한 색) -->

    <!-- 섹션 제목 (재생 / 목록 / 관리) -->
    <style name="SettingSection">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textColor">@color/brand</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 한 줄(스위치 항목) -->
    <style name="SettingRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:minHeight">60dp</item>
    </style>

    <!-- 한 줄(눌러서 이동하는 항목) -->
    <style name="SettingRowClickable" parent="SettingRow">
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <!-- 제목+설명 묶음 (왼쪽, 남은 공간 차지) -->
    <style name="SettingTexts">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- 항목 제목 -->
    <style name="SettingTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- 항목 설명(작은 회색 글씨) -->
    <style name="SettingDesc">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- 현재 선택값(브랜드 색으로 강조) -->
    <style name="SettingValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:textColor">@color/brand</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 항목 사이 구분선 -->
    <style name="SettingDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginEnd">20dp</item>
        <item name="android:background">#EEEEEE</item>
    </style>

    <!-- 오른쪽 화살표(›) -->
    <style name="SettingChevron">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">24sp</item>
    </style>

</resources>
